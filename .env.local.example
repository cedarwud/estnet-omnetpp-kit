# Optional local overrides for this project.
# Copy to .env.local and adjust values for your machine if needed.

# Example: limit parallel jobs on a smaller VM.
# export BUILD_JOBS=4

# Example: place generated directories on a larger disk.
# export BUILD_DIR="${PROJECT_ROOT}/build"
# export SOURCES_DIR="${PROJECT_ROOT}/sources"
# export THIRD_PARTY_DIR="${PROJECT_ROOT}/third_party"

# Example: override refs or pins only for local experimentation.
# export OSGEARTH_REF_METHOD_A="osgearth-2.7"
# export OSGEARTH_REF_METHOD_B="osgearth-2.7"

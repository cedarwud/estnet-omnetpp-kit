#!/usr/bin/env bash
# shellcheck shell=bash

_paths_root="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

export PROJECT_ROOT="${PROJECT_ROOT:-${WORKSPACE_ROOT:-${_paths_root}}}"
export WORKSPACE_ROOT="${WORKSPACE_ROOT:-${PROJECT_ROOT}}"
export DOCS_DIR="${DOCS_DIR:-${PROJECT_ROOT}/docs}"
export SCRIPTS_DIR="${SCRIPTS_DIR:-${PROJECT_ROOT}/scripts}"
export PATCH_DIR="${PATCH_DIR:-${SCRIPTS_DIR}/patches}"
export LOG_DIR="${LOG_DIR:-${PROJECT_ROOT}/logs}"
export STATE_DIR="${STATE_DIR:-${PROJECT_ROOT}/state}"
export SOURCES_DIR="${SOURCES_DIR:-${PROJECT_ROOT}/sources}"
export BUILD_DIR="${BUILD_DIR:-${PROJECT_ROOT}/build}"
export THIRD_PARTY_DIR="${THIRD_PARTY_DIR:-${PROJECT_ROOT}/third_party}"
export THIRD_PARTY_INSTALL_DIR="${THIRD_PARTY_INSTALL_DIR:-${THIRD_PARTY_DIR}/install}"

export OMNETPP_DIR="${OMNETPP_DIR:-${PROJECT_ROOT}/omnetpp-${OMNETPP_VERSION:-5.5.1}}"
export OMNETPP_551_OSG_CFLAGS_PATCH="${OMNETPP_551_OSG_CFLAGS_PATCH:-${PATCH_DIR}/omnetpp-5.5.1-local-osg-cflags.patch}"
export OMNETPP_IDE_BUILD_BASE="${OMNETPP_IDE_BUILD_BASE:-${BUILD_DIR}/omnetpp-ide}"
export INET_DIR="${INET_DIR:-${PROJECT_ROOT}/inet}"
export INET_SOURCE_DIR="${INET_SOURCE_DIR:-${SOURCES_DIR}/inet${INET_VERSION:-4.2.0}}"
export INET_420_OSG_LINK_PATCH="${INET_420_OSG_LINK_PATCH:-${PATCH_DIR}/inet-4.2-local-osg-link.patch}"

export OPENSCENEGRAPH_SOURCE_DIR="${OPENSCENEGRAPH_SOURCE_DIR:-${SOURCES_DIR}/OpenSceneGraph}"
export OPENSCENEGRAPH_BUILD_DIR="${OPENSCENEGRAPH_BUILD_DIR:-${BUILD_DIR}/openscenegraph}"
export OPENSCENEGRAPH_PREFIX="${OPENSCENEGRAPH_PREFIX:-${THIRD_PARTY_INSTALL_DIR}/openscenegraph}"

export OSGEARTH_SOURCE_DIR="${OSGEARTH_SOURCE_DIR:-${SOURCES_DIR}/osgEarth}"
export OSGEARTH_27A_BUILD_DIR="${OSGEARTH_27A_BUILD_DIR:-${BUILD_DIR}/osgearth-2.7-method-a}"
export OSGEARTH_27A_PREFIX="${OSGEARTH_27A_PREFIX:-${THIRD_PARTY_INSTALL_DIR}/osgearth-2.7-method-a}"
export OSGEARTH_27B_BUILD_DIR="${OSGEARTH_27B_BUILD_DIR:-${BUILD_DIR}/osgearth-2.7-method-b}"
export OSGEARTH_27B_PREFIX="${OSGEARTH_27B_PREFIX:-${THIRD_PARTY_INSTALL_DIR}/osgearth-2.7-method-b}"
export OSGEARTH_27_COMPAT_PATCH="${OSGEARTH_27_COMPAT_PATCH:-${PATCH_DIR}/osgearth-2.7-osg36-gcc9-compat.patch}"

export ESTNET_DIR="${ESTNET_DIR:-${PROJECT_ROOT}/estnet}"
export ESTNET_TEMPLATE_DIR="${ESTNET_TEMPLATE_DIR:-${PROJECT_ROOT}/estnet-template}"
export ESTNET_SOURCE_DIR="${ESTNET_SOURCE_DIR:-${SOURCES_DIR}/estnet}"
export ESTNET_TEMPLATE_SOURCE_DIR="${ESTNET_TEMPLATE_SOURCE_DIR:-${SOURCES_DIR}/estnet-template}"
export ESTNET_TEMPLATE_09_TIME_REF_PATCH="${ESTNET_TEMPLATE_09_TIME_REF_PATCH:-${PATCH_DIR}/estnet-template-0.9-global-julian-date.patch}"

unset _paths_root

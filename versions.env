#!/usr/bin/env bash
# shellcheck shell=bash

export OMNETPP_VERSION="${OMNETPP_VERSION:-5.5.1}"
export OMNETPP_REPO_URL="${OMNETPP_REPO_URL:-https://github.com/omnetpp/omnetpp.git}"
export OMNETPP_REF="${OMNETPP_REF:-omnetpp-${OMNETPP_VERSION}}"
export OMNETPP_COMMIT="${OMNETPP_COMMIT:-f0a213dad1597c6ff9934b6320da828c99531762}"
export OMNETPP_IDE_MAIN_REPO_URL="${OMNETPP_IDE_MAIN_REPO_URL:-https://download.eclipse.org/releases/2019-03}"
export OMNETPP_IDE_UPDATE_REPO_URL="${OMNETPP_IDE_UPDATE_REPO_URL:-https://download.eclipse.org/eclipse/updates/4.11/R-4.11-201903070500}"
export OMNETPP_IDE_CDT_REPO_URL="${OMNETPP_IDE_CDT_REPO_URL:-https://download.eclipse.org/tools/cdt/releases/9.7/cdt-9.7.2}"

export INET_VERSION="${INET_VERSION:-4.2.0}"
export INET_REPO_URL="${INET_REPO_URL:-https://github.com/inet-framework/inet.git}"
export INET_REF="${INET_REF:-v${INET_VERSION}}"
export INET_COMMIT="${INET_COMMIT:-cb6c37b3dcb76b0cecf584e87e777d965bf1ca6c}"

export OPENSCENEGRAPH_REPO_URL="${OPENSCENEGRAPH_REPO_URL:-https://github.com/openscenegraph/OpenSceneGraph.git}"
export OPENSCENEGRAPH_VERSION="${OPENSCENEGRAPH_VERSION:-3.6.5}"
export OPENSCENEGRAPH_REF="${OPENSCENEGRAPH_REF:-OpenSceneGraph-${OPENSCENEGRAPH_VERSION}}"
export OPENSCENEGRAPH_COMMIT="${OPENSCENEGRAPH_COMMIT:-a827840baf0786d72e11ac16d5338a4ee25779db}"

export OSGEARTH_TARGET_SERIES="${OSGEARTH_TARGET_SERIES:-2.7}"
export OSGEARTH_REPO_URL="${OSGEARTH_REPO_URL:-https://github.com/gwaldron/osgearth.git}"
export OSGEARTH_REF_METHOD_A="${OSGEARTH_REF_METHOD_A:-osgearth-2.7}"
export OSGEARTH_REF_METHOD_B="${OSGEARTH_REF_METHOD_B:-osgearth-2.7}"
export OSGEARTH_COMMIT="${OSGEARTH_COMMIT:-25ce0e1b7a47311d1c19f5e76f208d7cd4388f94}"

export ESTNET_REPO_URL="${ESTNET_REPO_URL:-https://github.com/estnet-framework/estnet.git}"
export ESTNET_REF="${ESTNET_REF:-v1.0}"
export ESTNET_COMMIT="${ESTNET_COMMIT:-2355ffe3c396510a182debf7c2a57d6559df942b}"

export ESTNET_TEMPLATE_REPO_URL="${ESTNET_TEMPLATE_REPO_URL:-https://github.com/estnet-framework/estnet-template.git}"
export ESTNET_TEMPLATE_REF="${ESTNET_TEMPLATE_REF:-v0.9}"
export ESTNET_TEMPLATE_COMMIT="${ESTNET_TEMPLATE_COMMIT:-fb76667fb43a2935ecb4bccf00cf58e88e26c407}"

export BUILD_JOBS="${BUILD_JOBS:-$(nproc 2>/dev/null || echo 4)}"
